<?xml version="1.0" encoding="utf-8"?><x:worksheet xmlns:x="http://schemas.openxmlformats.org/spreadsheetml/2006/main"><x:sheetViews><x:sheetView showGridLines="0" workbookViewId="0" /></x:sheetViews><x:sheetFormatPr baseColWidth="8" defaultRowHeight="15" /><x:cols><x:col min="1" max="1" width="18" customWidth="1" /><x:col min="2" max="2" width="95" customWidth="1" /><x:col min="4" max="4" width="18" customWidth="1" /><x:col min="5" max="5" width="12" customWidth="1" /></x:cols><x:sheetData><x:row r="1" ht="24" customHeight="1"><x:c r="A1" s="12" t="inlineStr"><x:is><x:t xml:space="preserve">ITAM - Workbook Testing</x:t></x:is></x:c></x:row><x:row r="2" ht="26" customHeight="1"><x:c r="A2" s="2" t="inlineStr"><x:is><x:t xml:space="preserve">Workbook khusus skenario testing/UAT semua modul. Mulai dari sheet Ringkasan untuk coverage, lalu gunakan sheet Alur_Per_Role untuk membaca alur user per role, dan buka Semua_Skenario atau sheet modul untuk eksekusi test case detail.</x:t></x:is></x:c></x:row><x:row r="3" ht="26" customHeight="1"><x:c r="A3" s="13" t="n" /><x:c r="B3" s="13" t="n" /></x:row><x:row r="4" ht="26" customHeight="1"><x:c r="A4" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Tujuan</x:t></x:is></x:c><x:c r="B4" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">Menjadi master workbook skenario testing semua modul.</x:t></x:is></x:c><x:c r="D4" s="5" t="inlineStr"><x:is><x:t xml:space="preserve">Ringkasan Cepat</x:t></x:is></x:c></x:row><x:row r="5" ht="26" customHeight="1"><x:c r="A5" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Struktur Workbook</x:t></x:is></x:c><x:c r="B5" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">1) Ringkasan = coverage modul dan status. 2) Alur_Per_Role = siapa login, masuk ke modul mana, lalu ngapain. 3) Matriks_Role_Modul = akses role vs modul. 4) Semua_Skenario + sheet modul = eksekusi test detail.</x:t></x:is></x:c><x:c r="D5" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">Total Skenario</x:t></x:is></x:c><x:c r="E5" s="7"><x:f>COUNTIF(Semua_Skenario!$A:$A,"&lt;&gt;")-3</x:f><x:v>243</x:v></x:c></x:row><x:row r="6" ht="26" customHeight="1"><x:c r="A6" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Cara Pakai Disarankan</x:t></x:is></x:c><x:c r="B6" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">Pahami dahulu alur user di Alur_Per_Role, lalu tandai skenario detail di sheet modul. Ini membuat workbook lebih mudah dipahami untuk UAT, demo, dan diskusi fitur.</x:t></x:is></x:c><x:c r="D6" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">High Priority</x:t></x:is></x:c><x:c r="E6" s="7"><x:f>COUNTIF(Semua_Skenario!$H:$H,"High")</x:f><x:v>144</x:v></x:c></x:row><x:row r="7" ht="26" customHeight="1"><x:c r="A7" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Istilah</x:t></x:is></x:c><x:c r="B7" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">Istilah modul, fitur, dan role disesuaikan dengan kode, UI, dan dokumen repo ITAM yang ada saat ini.</x:t></x:is></x:c><x:c r="D7" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">Medium Priority</x:t></x:is></x:c><x:c r="E7" s="7"><x:f>COUNTIF(Semua_Skenario!$H:$H,"Medium")</x:f><x:v>94</x:v></x:c></x:row><x:row r="8" ht="26" customHeight="1"><x:c r="A8" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Sumber Utama</x:t></x:is></x:c><x:c r="B8" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">Repo GitHub ITAM + dokumen diagram per modul, panduan penggunaan lengkap, matriks akses role, dan alur end-to-end.</x:t></x:is></x:c><x:c r="D8" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">Pass</x:t></x:is></x:c><x:c r="E8" s="7"><x:f>COUNTIF(Semua_Skenario!$M:$M,"Pass")</x:f><x:v>0</x:v></x:c></x:row><x:row r="9" ht="26" customHeight="1"><x:c r="A9" s="14" t="inlineStr"><x:is><x:t xml:space="preserve">Status Eksekusi</x:t></x:is></x:c><x:c r="B9" s="4" t="inlineStr"><x:is><x:t xml:space="preserve">Gunakan Not Started, In Progress, Pass, Fail, atau Blocked.</x:t></x:is></x:c><x:c r="D9" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">Fail</x:t></x:is></x:c><x:c r="E9" s="7"><x:f>COUNTIF(Semua_Skenario!$M:$M,"Fail")</x:f><x:v>0</x:v></x:c></x:row><x:row r="10" ht="26" customHeight="1"><x:c r="A10" s="13" t="inlineStr"><x:is><x:t xml:space="preserve">Catatan</x:t></x:is></x:c><x:c r="B10" s="13" t="inlineStr"><x:is><x:t xml:space="preserve">Kolom Actual Result dan Catatan dipakai untuk hasil UAT nyata. Jangan ubah kolom referensi jika ingin jejak sumber tetap rapi.</x:t></x:is></x:c><x:c r="D10" s="6" t="inlineStr"><x:is><x:t xml:space="preserve">Blocked</x:t></x:is></x:c><x:c r="E10" s="7"><x:f>COUNTIF(Semua_Skenario!$M:$M,"Blocked")</x:f><x:v>0</x:v></x:c></x:row></x:sheetData><x:mergeCells><x:mergeCell ref="A2:H2" /><x:mergeCell ref="A1:H1" /></x:mergeCells><x:pageMargins left="0.7" right="0.7" top="0.75" bottom="0.75" header="0.3" footer="0.3" /></x:worksheet>